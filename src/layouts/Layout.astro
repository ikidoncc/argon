---
import '../styles/global.css';
import {
  getLangFromUrl,
  useTranslations,
  getLocalizedLink,
  getLocalizedPath,
} from '../utils/i18n';
import { Sun, Moon, Monitor, Globe, Tag, Info } from '@lucide/astro';
import CustomSelect from '../components/CustomSelect.astro';

interface Props {
  title: string;
  description?: string;
  cover?: string;
}

const {
  title,
  description = 'Argon is a personal blog and knowledge repository where I share articles, notes, experiments, and insights about software engineering, computer science, mathematics, physics, and anything else worth understanding.',
  cover,
} = Astro.props;

// Determine current URL for canonical links
const canonicalURL = new URL(
  Astro.url.pathname,
  Astro.site || 'https://ikidoncc.github.io/argon'
);

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const oppositeLang = lang === 'en' ? 'pt' : 'en';
const switchLangUrl = getLocalizedPath(Astro.url, oppositeLang);
---

<!doctype html>
<html lang={lang} data-theme-mode="auto">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="icon"
      type="image/svg+xml"
      href={`${import.meta.env.BASE_URL}favicon.svg`}
    />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Argon RSS Feed"
      href={`${import.meta.env.BASE_URL}rss.xml`}
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {cover && <meta property="og:image" content={new URL(cover, Astro.url)} />}

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    {
      cover && (
        <meta property="twitter:image" content={new URL(cover, Astro.url)} />
      )
    }

    <!-- Inline script to prevent theme flash -->
    <script is:inline>
      const getThemeMode = () => {
        if (
          typeof localStorage !== 'undefined' &&
          localStorage.getItem('theme-mode')
        ) {
          return localStorage.getItem('theme-mode');
        }
        return 'auto';
      };

      const themeMode = getThemeMode();
      document.documentElement.setAttribute('data-theme-mode', themeMode);

      const updateThemeClass = (mode) => {
        if (
          mode === 'dark' ||
          (mode === 'auto' &&
            window.matchMedia('(prefers-color-scheme: dark)').matches)
        ) {
          document.documentElement.setAttribute('data-theme', 'dark');
        } else {
          document.documentElement.removeAttribute('data-theme');
        }
      };

      updateThemeClass(themeMode);
    </script>
  </head>
  <body>
    <header class="header">
      <div class="container header-container">
        <a href={getLocalizedLink('/', lang)} class="logo">
          <span class="logo-accent">&gt;_</span> Argon
        </a>
        <nav class="nav">
          <a href={getLocalizedLink('/tags', lang)} class="nav-link">
            <Tag size={16} class="nav-icon" />
            <span>{t('nav.tags')}</span>
          </a>
          <a href={getLocalizedLink('/about', lang)} class="nav-link">
            <Info size={16} class="nav-icon" />
            <span>{t('nav.about')}</span>
          </a>

          <div class="nav-divider"></div>

          <!-- Language Select -->
          <CustomSelect
            id="lang-select"
            label={t('lang.label')}
            value={lang}
            options={[
              { value: 'pt', text: 'PT' },
              { value: 'en', text: 'EN' },
            ]}
          >
            <Globe size={16} slot="icon" />
          </CustomSelect>

          <!-- Theme Select -->
          <CustomSelect
            id="theme-select"
            label="Theme"
            value="auto"
            options={[
              { value: 'auto', text: t('theme.auto') },
              { value: 'light', text: t('theme.light') },
              { value: 'dark', text: t('theme.dark') },
            ]}
          >
            <Sun class="select-theme-icon sun-icon" size={16} slot="icon" />
            <Moon class="select-theme-icon moon-icon" size={16} slot="icon" />
            <Monitor class="select-theme-icon monitor-icon" size={16} slot="icon" />
          </CustomSelect>
        </nav>
      </div>
    </header>

    <main data-pagefind-body>
      <slot />
    </main>

    <footer class="footer">
      <div class="container footer-container">
        <p class="footer-desc">
          {t('footer.desc')}
        </p>
        <div class="footer-links">
          <a
            href="https://astro.build"
            target="_blank"
            rel="noopener noreferrer"
            class="footer-link"
          >
            {t('footer.built')} Astro
          </a>
          <span class="footer-dot">&middot;</span>
          <a
            href="https://pages.github.com"
            target="_blank"
            rel="noopener noreferrer"
            class="footer-link"
          >
            {t('footer.hosted')} GitHub Pages
          </a>
          <span class="footer-dot">&middot;</span>
          <a
            href="https://github.com/ikidoncc/argon"
            target="_blank"
            rel="noopener noreferrer"
            class="footer-link"
          >
            {t('footer.source')}
          </a>
          <span class="footer-dot">&middot;</span>
          <a href={`${import.meta.env.BASE_URL}rss.xml`} class="footer-link">
            RSS
          </a>
        </div>
        <p class="footer-copy">
          &copy; {new Date().getFullYear()} Argon
        </p>
      </div>
    </footer>

    <script>
      // --- Theme Select Logic ---
      const themeSelectEl = document.getElementById('theme-select');

      if (themeSelectEl) {
        // Sync initial value from stored preference
        const currentMode =
          document.documentElement.getAttribute('data-theme-mode') || 'auto';

        // Programmatically select the correct option on load
        const initialOpt = themeSelectEl.querySelector<HTMLLIElement>(
          `.cselect-option[data-value="${currentMode}"]`
        );
        if (initialOpt) {
          themeSelectEl
            .querySelectorAll('.cselect-option')
            .forEach((o) => {
              o.classList.remove('active');
              o.setAttribute('aria-selected', 'false');
            });
          initialOpt.classList.add('active');
          initialOpt.setAttribute('aria-selected', 'true');
          const textEl = themeSelectEl.querySelector('.cselect-text');
          if (textEl) textEl.textContent = initialOpt.textContent!.trim();
          themeSelectEl.dataset.value = currentMode;
        }

        const updateTheme = (mode: string) => {
          if (
            mode === 'dark' ||
            (mode === 'auto' &&
              window.matchMedia('(prefers-color-scheme: dark)').matches)
          ) {
            document.documentElement.setAttribute('data-theme', 'dark');
          } else {
            document.documentElement.removeAttribute('data-theme');
          }
        };

        themeSelectEl.addEventListener('select-change', ((e: CustomEvent) => {
          const nextMode = e.detail.value;
          document.documentElement.setAttribute('data-theme-mode', nextMode);
          localStorage.setItem('theme-mode', nextMode);
          updateTheme(nextMode);
        }) as EventListener);

        // Listen for system changes in auto mode
        window
          .matchMedia('(prefers-color-scheme: dark)')
          .addEventListener('change', () => {
            const mode =
              document.documentElement.getAttribute('data-theme-mode') ||
              'auto';
            if (mode === 'auto') {
              updateTheme('auto');
            }
          });
      }

      // --- Language Select Logic ---
      const langSelectEl = document.getElementById('lang-select');

      if (langSelectEl) {
        langSelectEl.addEventListener('select-change', ((e: CustomEvent) => {
          const targetLang = e.detail.value;
          const currentLang = document.documentElement.getAttribute('lang');
          if (targetLang !== currentLang) {
            // Build the switch URL by replacing the lang segment
            const pathname = window.location.pathname;
            const newPath = pathname.replace(
              /\/(?:en|pt)\//,
              `/${targetLang}/`
            );
            window.location.href = newPath;
          }
        }) as EventListener);
      }
    </script>
  </body>
</html>

<style>
  /* Header styling */
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--glass-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--glass-border);
    padding: 1rem 0;
  }

  .header-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-text);
    display: flex;
    align-items: center;
    gap: 0.25rem;
    letter-spacing: -0.03em;
  }

  .logo-accent {
    color: var(--color-primary);
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  /* Nav links with icons */
  .nav-link {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--color-text-muted);
    font-size: 0.95rem;
    transition: var(--transition-fast);
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.5rem;
    border-radius: var(--radius-sm);
  }

  .nav-link:hover {
    color: var(--color-text);
    background: var(--color-bg-surface-hover);
  }

  .nav-icon {
    flex-shrink: 0;
  }

  /* Divider between nav links and selects */
  .nav-divider {
    width: 1px;
    height: 1.25rem;
    background: var(--color-border);
    margin: 0 0.25rem;
  }

  /* Theme icon in select — show/hide based on mode */
  .select-theme-icon {
    display: none;
    color: var(--color-text-muted);
    flex-shrink: 0;
    pointer-events: none;
  }

  :root[data-theme-mode='light'] .sun-icon {
    display: block;
  }
  :root[data-theme-mode='dark'] .moon-icon {
    display: block;
  }
  :root[data-theme-mode='auto'] .monitor-icon {
    display: block;
  }

  /* Footer styling */
  .footer {
    border-top: 1px solid var(--color-border);
    padding: 2.5rem 0;
    background: var(--color-bg-surface);
    margin-top: auto;
  }

  .footer-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    text-align: center;
  }

  .footer-desc {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 0;
    max-width: 500px;
    line-height: 1.5;
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer-link {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    transition: var(--transition-fast);
  }

  .footer-link:hover {
    color: var(--color-primary);
  }

  .footer-dot {
    color: var(--color-border);
    font-size: 0.85rem;
    user-select: none;
  }

  .footer-copy {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 0;
    opacity: 0.7;
  }

  @media (max-width: 600px) {
    .header-container {
      flex-direction: column;
      gap: 1rem;
    }

    .nav {
      flex-wrap: wrap;
      justify-content: center;
    }
  }
</style>
