---
import PageLayout from '../../layouts/PageLayout.astro';
import { getLangFromUrl, useTranslations } from '../../utils/i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<PageLayout title={t('about.title')} description={t('about.desc')}>
  <div class="about-container">
    <div class="about-grid">
      <!-- Profile Card -->
      <section class="glass-card profile-card">
        <h2 class="profile-name">{t('about.maintainer')}</h2>
        <p class="profile-title">{t('about.maintainer.title')}</p>
        <p class="profile-bio">
          {t('about.maintainer.bio')}
        </p>
        <div class="social-links">
          <a
            href="https://github.com/ikidoncc/argon"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-primary"
          >
            {t('about.githubProfile')}
          </a>
        </div>
      </section>

      <!-- Project details -->
      <div class="about-info">
        <section class="info-section">
          <h3>{t('about.mission')}</h3>
          <p>
            {t('about.mission.1')}
          </p>
          <p>
            {t('about.mission.2')}
          </p>
        </section>

        <section class="info-section">
          <h3>{t('about.stack')}</h3>
          <p>
            {t('about.stack.desc')}
          </p>
          <ul class="stack-list">
            <li>
              <strong>Astro v6</strong>: {t('about.stack.astro')}
            </li>
            <li>
              <strong>Tailwind CSS v4</strong>: {t('about.stack.tailwind')}
            </li>
            <li>
              <strong>GitHub Pages & Actions</strong>: {t('about.stack.github')}
            </li>
            <li>
              <strong>Markdown & Schema</strong>: {t('about.stack.markdown')}
            </li>
          </ul>
        </section>
      </div>
    </div>
  </div>
</PageLayout>

<style>
  .about-container {
    padding-top: 1rem;
  }

  .about-grid {
    display: grid;
    grid-template-cols: 1fr;
    gap: 3rem;
  }

  @media (min-width: 768px) {
    .about-grid {
      grid-template-cols: 280px 1fr;
    }
  }

  /* Profile Card styling */
  .profile-card {
    position: relative;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    overflow: hidden;
    align-self: start;
  }

  .profile-name {
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
    letter-spacing: -0.02em;
  }

  .profile-title {
    font-size: 0.9rem;
    color: var(--color-secondary);
    font-weight: 600;
    margin-bottom: 1.5rem;
  }

  .profile-bio {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin-bottom: 2rem;
  }

  .social-links {
    width: 100%;
  }

  .social-links a {
    width: 100%;
    text-shadow: none;
    font-size: 0.95rem;
  }

  /* Info styling */
  .about-info {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .info-section h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    letter-spacing: -0.03em;
  }

  .info-section p {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .stack-list {
    margin-top: 1rem;
    padding-left: 1.25rem;
  }

  .stack-list li {
    color: var(--color-text-muted);
    font-size: 1rem;
    margin-bottom: 0.75rem;
    line-height: 1.6;
  }

  .stack-list li strong {
    color: var(--color-text);
  }
</style>
