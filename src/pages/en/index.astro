---
import Layout from '../../layouts/Layout.astro';
import { getPosts } from '../../utils/posts';
import {
  getLangFromUrl,
  useTranslations,
  getLocalizedLink,
} from '../../utils/i18n';
import { ArrowRight, Search } from '@lucide/astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const posts = await getPosts(lang);

// Formatting the date helper
const formatDate = (date: Date) => {
  return new Date(date).toLocaleDateString(lang === 'en' ? 'en-US' : 'pt-BR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};
---

<Layout title={`Argon | ${t('hero.title')}`}>
  <section class="hero-section">
    <div class="container hero-container">
      <h1 class="hero-title">
        {
          lang === 'en' ? (
            <>
              Exploring <span class="text-brand-primary">Technology</span>,{' '}
              <span class="text-brand-primary">Science</span>, and{' '}
              <span class="text-brand-primary">Lifelong Learning</span>
            </>
          ) : (
            <>
              Explorando <span class="text-brand-primary">Tecnologia</span>,{' '}
              <span class="text-brand-primary">Ciência</span> e{' '}
              <span class="text-brand-primary">Aprendizado Contínuo</span>
            </>
          )
        }
      </h1>
      <p class="hero-subtitle">
        {t('hero.subtitle')}
      </p>

      <!-- Inline Search -->
      <div
        class="hero-search"
        data-lang={lang}
        data-no-results={t('search.noResults')}
        data-read-article={t('post.readMore')}
      >
        <div class="search-box glass-card">
          <Search class="search-icon" size={20} />
          <input
            type="text"
            id="hero-search-input"
            placeholder={t('search.placeholder')}
            autocomplete="off"
          />
          <div id="hero-search-spinner" class="spinner hidden"></div>
        </div>
        <div id="hero-search-results" class="results-list"></div>
      </div>
    </div>
  </section>

  <section class="posts-section container">
    <h2 class="section-title">{t('home.latest')}</h2>

    {
      posts.length === 0 ? (
        <div class="glass-card no-posts">
          <p>{t('home.noPosts')}</p>
        </div>
      ) : (
        <div class="posts-grid">
          {posts.map((post) => (
            <article class="glass-card post-card">
              {post.data.cover && (
                <a
                  href={getLocalizedLink(`posts/${post.data.slug}`, lang)}
                  class="post-cover-link"
                >
                  <div class="post-cover-wrapper">
                    <img
                      src={post.data.cover.src}
                      alt={post.data.title}
                      class="post-cover"
                    />
                  </div>
                </a>
              )}
              <div class="post-content">
                <div class="post-meta">
                  <time datetime={post.data.date.toISOString()}>
                    {formatDate(post.data.date)}
                  </time>
                  <div class="post-tags">
                    {post.data.tags.slice(0, 2).map((tag) => (
                      <span class="post-tag">#{tag}</span>
                    ))}
                  </div>
                </div>
                <h3 class="post-title">
                  <a href={getLocalizedLink(`posts/${post.data.slug}`, lang)}>
                    {post.data.title}
                  </a>
                </h3>
                <p class="post-excerpt">
                  {post.data.description ||
                    (lang === 'en'
                      ? `Deep dive exploration of ${post.data.title.toLowerCase()}. Learn the core principles, design choices, and systems architecture.`
                      : `Análise profunda sobre ${post.data.title.toLowerCase()}. Aprenda os princípios fundamentais, escolhas de design e arquitetura de sistemas.`)}
                </p>
                <a
                  href={getLocalizedLink(`posts/${post.data.slug}`, lang)}
                  class="read-more-btn"
                >
                  {t('post.readMore')}
                  <ArrowRight class="arrow-icon" size={16} strokeWidth={2.5} />
                </a>
              </div>
            </article>
          ))}
        </div>
      )
    }
  </section>
</Layout>

<script>
  // ---- Pagefind-based inline search on the home page ----
  let pagefind: any = null;

  const container = document.querySelector('.hero-search') as HTMLDivElement;
  const noResultsText = container?.dataset.noResults || 'No results found for';
  const readArticleText = container?.dataset.readArticle || 'Read Article';

  const searchInput = document.getElementById(
    'hero-search-input'
  ) as HTMLInputElement;
  const searchResults = document.getElementById(
    'hero-search-results'
  ) as HTMLDivElement;
  const spinner = document.getElementById(
    'hero-search-spinner'
  ) as HTMLDivElement;

  async function initPagefind() {
    if (!pagefind) {
      try {
        const path = '/argon/pagefind/pagefind.js';
        pagefind = await import(path);
        await pagefind.init();
      } catch (e) {
        console.error(
          'Failed to load pagefind index. Search might not be indexed yet.',
          e
        );
      }
    }
  }

  async function performSearch(query: string) {
    if (!pagefind) return;

    if (!query.trim()) {
      searchResults.innerHTML = '';
      return;
    }

    spinner.classList.remove('hidden');

    try {
      const search = await pagefind.search(query);

      if (search.results.length === 0) {
        searchResults.innerHTML = `<div class="no-results glass-card"><p>${noResultsText} "${query}"</p></div>`;
        spinner.classList.add('hidden');
        return;
      }

      const resultsToRender = search.results.slice(0, 10);
      const data = await Promise.all(
        resultsToRender.map((r: any) => r.data())
      );

      searchResults.innerHTML = data
        .map(
          (item: any) => `
          <article class="glass-card result-card">
            <h3 class="result-title">
              <a href="${item.url}">${item.meta.title || 'Untitled'}</a>
            </h3>
            <p class="result-excerpt">${item.excerpt || ''}</p>
            <a href="${item.url}" class="result-link">${readArticleText} &rarr;</a>
          </article>
        `
        )
        .join('');
    } catch (e) {
      console.error('Search error', e);
    } finally {
      spinner.classList.add('hidden');
    }
  }

  if (searchInput) {
    searchInput.addEventListener('focus', initPagefind);

    let debounceTimeout: ReturnType<typeof setTimeout>;
    searchInput.addEventListener('input', (e) => {
      const query = (e.target as HTMLInputElement).value;
      clearTimeout(debounceTimeout);
      debounceTimeout = setTimeout(() => {
        performSearch(query);
      }, 300);
    });
  }
</script>

<style>
  /* Hero Section */
  .hero-section {
    position: relative;
    padding: 6rem 0 4rem;
    overflow: hidden;
    text-align: center;
  }

  .hero-container {
    position: relative;
    z-index: 10;
    max-width: 900px;
  }

  .hero-title {
    font-size: 3.5rem;
    line-height: 1.15;
    letter-spacing: -0.05em;
    margin-bottom: 1.5rem;
    font-weight: 800;
  }

  .text-brand-primary {
    color: var(--color-primary);
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* Hero Search */
  .hero-search {
    margin-top: 2.5rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .search-box {
    display: flex;
    align-items: center;
    padding: 0.75rem 1.25rem;
    border-radius: var(--radius-md);
    transition: var(--transition-fast);
  }

  .search-box:focus-within {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px var(--color-accent-glow);
  }

  .search-icon {
    color: var(--color-text-muted);
    margin-right: 0.75rem;
    flex-shrink: 0;
  }

  input[type='text'] {
    flex: 1;
    background: none;
    border: none;
    color: var(--color-text);
    font-size: 1.1rem;
    font-family: var(--font-sans);
    outline: none;
  }

  input[type='text']::placeholder {
    color: var(--color-text-muted);
  }

  /* Spinner */
  .spinner {
    width: 20px;
    height: 20px;
    border: 2px solid var(--color-border);
    border-top-color: var(--color-primary);
    border-radius: var(--radius-full);
    animation: spin 0.8s linear infinite;
  }

  .hidden {
    display: none;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  /* Search Results */
  .results-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-top: 1.5rem;
    text-align: left;
  }

  .no-results {
    padding: 2.5rem;
    text-align: center;
    color: var(--color-text-muted);
  }

  :global(.result-card) {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  :global(.result-title) {
    font-size: 1.35rem;
    letter-spacing: -0.02em;
  }

  :global(.result-title a) {
    color: var(--color-text);
  }

  :global(.result-title a:hover) {
    color: var(--color-primary);
  }

  :global(.result-excerpt) {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  :global(.result-excerpt mark) {
    background-color: var(--color-accent-glow);
    color: var(--color-secondary);
    font-weight: 600;
    padding: 0.1rem 0.25rem;
    border-radius: var(--radius-sm);
    border: 1px solid rgba(0, 240, 255, 0.15);
  }

  :global(.result-link) {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-primary);
    align-self: start;
    transition: var(--transition-fast);
  }

  :global(.result-link:hover) {
    color: var(--color-primary-hover);
    transform: translateX(2px);
  }

  /* Posts Grid */
  .posts-section {
    padding-bottom: 6rem;
  }

  .section-title {
    font-size: 1.75rem;
    margin-bottom: 2rem;
    letter-spacing: -0.03em;
  }

  .no-posts {
    padding: 3rem;
    text-align: center;
    color: var(--color-text-muted);
  }

  .posts-grid {
    display: grid;
    grid-template-cols: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .posts-grid {
      grid-template-cols: repeat(2, 1fr);
    }
  }

  .post-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
  }

  .post-cover-link {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-bottom: 1px solid var(--glass-border);
  }

  .post-cover-wrapper {
    width: 100%;
    height: 100%;
  }

  .post-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: var(--transition-smooth);
  }

  .post-card:hover .post-cover {
    transform: scale(1.03);
  }

  .post-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .post-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .post-tags {
    display: flex;
    gap: 0.5rem;
  }

  .post-tag {
    color: var(--color-secondary);
    font-weight: 600;
  }

  .post-title {
    font-size: 1.35rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
    letter-spacing: -0.02em;
  }

  .post-title a {
    color: var(--color-text);
    transition: var(--transition-fast);
  }

  .post-title a:hover {
    color: var(--color-primary);
  }

  .post-excerpt {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    flex: 1;
  }

  .read-more-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-primary);
    transition: var(--transition-fast);
  }

  .read-more-btn:hover {
    color: var(--color-primary-hover);
  }

  .arrow-icon {
    transition: transform 0.2s ease;
  }

  .read-more-btn:hover .arrow-icon {
    transform: translateX(3px);
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 2.5rem;
    }
  }
</style>
