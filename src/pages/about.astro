---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="About Argon"
  description="Learn more about the project, the author, and the stack."
>
  <div class="about-container">
    <div class="about-grid">
      <!-- Profile Card -->
      <section class="glass-card profile-card">
        <div class="profile-glow"></div>
        <h2 class="profile-name">Argon Maintainer</h2>
        <p class="profile-title">Systems & Infrastructure Engineer</p>
        <p class="profile-bio">
          Passionate about building highly scalable distributed backends,
          investigating database internals, and optimizing software performance.
        </p>
        <div class="social-links">
          <a
            href="https://github.com/ikidoncc/argon"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-primary"
          >
            GitHub Profile
          </a>
        </div>
      </section>

      <!-- Project details -->
      <div class="about-info">
        <section class="info-section">
          <h3>The Mission</h3>
          <p>
            Argon was created to serve as a high-quality, personal journal for
            documenting technical explorations, implementation details, and
            systems engineering concepts.
          </p>
          <p>
            By sharing detailed write-ups on networking protocols, database
            engines, and runtime systems, the goal is to contribute clean,
            accessible reference material to the developer community.
          </p>
        </section>

        <section class="info-section">
          <h3>The Technology Stack</h3>
          <p>
            Argon is built on modern static-site architectures to achieve
            near-instantaneous load times, top-tier SEO rating, and simple
            maintenance:
          </p>
          <ul class="stack-list">
            <li>
              <strong>Astro v6</strong>: The web framework for building
              content-focused websites.
            </li>
            <li>
              <strong>Tailwind CSS v4</strong>: Utilizes the new Vite engine for
              high-speed utility compilation.
            </li>
            <li>
              <strong>GitHub Pages & Actions</strong>: Automated integration and
              deployment pipeline.
            </li>
            <li>
              <strong>Markdown & Schema</strong>: Formatted content verified
              through Content Collections schemas.
            </li>
          </ul>
        </section>
      </div>
    </div>
  </div>
</PageLayout>

<style>
  .about-container {
    padding-top: 1rem;
  }

  .about-grid {
    display: grid;
    grid-template-cols: 1fr;
    gap: 3rem;
  }

  @media (min-width: 768px) {
    .about-grid {
      grid-template-cols: 280px 1fr;
    }
  }

  /* Profile Card styling */
  .profile-card {
    position: relative;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    overflow: hidden;
    align-self: start;
  }

  .profile-glow {
    position: absolute;
    top: -30%;
    width: 200px;
    height: 200px;
    background: radial-gradient(
      circle,
      var(--color-accent-glow) 0%,
      rgba(255, 255, 255, 0) 75%
    );
    z-index: -1;
    filter: blur(30px);
  }

  .profile-name {
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
    letter-spacing: -0.02em;
  }

  .profile-title {
    font-size: 0.9rem;
    color: var(--color-secondary);
    font-weight: 600;
    margin-bottom: 1.5rem;
  }

  .profile-bio {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin-bottom: 2rem;
  }

  .social-links {
    width: 100%;
  }

  .social-links a {
    width: 100%;
    text-shadow: none;
    font-size: 0.95rem;
  }

  /* Info styling */
  .about-info {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .info-section h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    letter-spacing: -0.03em;
  }

  .info-section p {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .stack-list {
    margin-top: 1rem;
    padding-left: 1.25rem;
  }

  .stack-list li {
    color: var(--color-text-muted);
    font-size: 1rem;
    margin-bottom: 0.75rem;
    line-height: 1.6;
  }

  .stack-list li strong {
    color: var(--color-text);
  }
</style>
